FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY ems/ai/requirements-runpod-inference.txt /tmp/requirements-runpod-inference.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements-runpod-inference.txt

COPY ems /app/ems

ENV PYTHONPATH=/app
ENV S305_AI_DATA_ROOT=/workspace/s305-ai-data
ENV S305_AI_OUTPUT_ROOT=/workspace/runs
ENV S305_CAPACITY_FACTOR_MODEL_PATH=/app/ems/ai/models/kpx_5min_capacity_factor_lightgbm/model.joblib

CMD ["python", "-m", "ems.ai.runpod.handler"]
