# ================================================================
# EMS Edge Simulator 환경변수 예시
#
# 사용법: 이 파일을 .env로 복사 후 환경에 맞게 수정
#   cp .env.example .env
#
# docker compose는 같은 디렉토리의 .env 파일을 자동으로 로드한다.
# ================================================================

# ── MQTT broker (EMS mosquitto) ─────────────────────────────────
# 같은 PC에서 EMS docker-compose가 떠있는 경우:
MQTT_HOST=host.docker.internal
MQTT_PORT=1883

# 원격 EMS 서버 사용 시 예시:
#   MQTT_HOST=ems.internal.example.com
#   MQTT_PORT=1883

# 별도 host에서 simulator만 띄울 때 (LAN):
#   MQTT_HOST=192.168.1.50
