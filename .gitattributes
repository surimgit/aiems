# 기본: 텍스트는 git 이 자동 감지, 체크아웃 시 OS 관습 따름
* text=auto

# 리눅스 컨테이너에서 실행되는 스크립트는 반드시 LF
# (Windows clone 시에도 CRLF 변환 금지 — 안 그러면 BusyBox sh 에서 깨짐)
*.sh            text eol=lf
*.template      text eol=lf
*.conf          text eol=lf
Dockerfile*     text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf

# 바이너리 (diff/merge 금지)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
