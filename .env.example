# ===== TimescaleDB (시계열 데이터 전용 - DB Writer 사용) =====
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_DB=timescale_db
TIMESCALE_USER=timescale_user
TIMESCALE_PASSWORD=
TIMESCALE_ROOT_PASSWORD=

# ===== PostgreSQL (state_write / ai / control DB 논리 분리) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_ROOT_PASSWORD=

# --- State Write DB (State 서비스) ---
STATE_DB=state_write_db
STATE_USER=state_user
STATE_PASSWORD=

# --- AI DB (AI 서비스) ---
AI_DB=ai_db
AI_USER=ai_user
AI_PASSWORD=

# --- Control DB (Control 서비스) ---
CONTROL_DB=control_db
CONTROL_USER=control_user
CONTROL_PASSWORD=

# ===== Redis (이벤트 버스 + 캐시) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=        # 필수! 비워두면 서비스 안 뜸

# ===== Redis Streams 토픽 이름 =====
STREAM_SENSOR_DATA=mg:sensor:data
STREAM_SENSOR_ALERT=mg:sensor:alert
STREAM_CONTROL_CMD=mg:control:cmd
STREAM_STATE_RESULT=mg:state:result
STREAM_AI_RESULT=mg:ai:result
STREAM_DB_WRITE=mg:db:write

# ===== MQTT =====
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883

# ===== API =====
API_SECRET_KEY=
JWT_SECRET=

# ===== OpenAI =====
OPENAI_API_KEY=
