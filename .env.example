# ============================================================================
# EMS .env (example)
# ----------------------------------------------------------------------------
# - 실제 .env 는 Git 에 커밋 금지 (.gitignore 에 .env, .env.* 등록됨)
# - 프로덕션 .env 는 Jenkins Managed File "ems-env" 로 관리
# - 패스워드/시크릿은 아래 기준으로 생성:
#     DB/Redis/MQTT 패스워드 : 24자 이상 영숫자 (특수문자 제외 권장, URL 인코딩 이슈 방지)
#     JWT_SECRET / API_SECRET: 32자 이상 hex
#     OPENAI_API_KEY         : OpenAI 콘솔에서 발급
# - 생성 명령어 예시 (Linux/macOS):
#     # 24자 영숫자
#     tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 24
#     # 32자 hex
#     openssl rand -hex 32
#     # Python 대안
#     python -c "import secrets; print(secrets.token_urlsafe(24))"
# ============================================================================

# ===== TimescaleDB (시계열 데이터 전용 - DB Writer 사용) =====
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_DB=timescale_db
TIMESCALE_USER=timescale_user
TIMESCALE_PASSWORD=                 # [필수] 24자 이상 영숫자
TIMESCALE_ROOT_PASSWORD=            # [필수] 24자 이상 영숫자

# ===== PostgreSQL (state_write / ai / control DB 논리 분리) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_ROOT_PASSWORD=             # [필수] 24자 이상 영숫자

# --- State Write DB (State 서비스) ---
STATE_DB=state_write_db
STATE_USER=state_user
STATE_PASSWORD=                     # [필수] 24자 이상 영숫자

# --- AI DB (AI 서비스) ---
AI_DB=ai_db
AI_USER=ai_user
AI_PASSWORD=                        # [필수] 24자 이상 영숫자

# --- Control DB (Control 서비스) ---
CONTROL_DB=control_db
CONTROL_USER=control_user
CONTROL_PASSWORD=                   # [필수] 24자 이상 영숫자

# ===== Redis (이벤트 버스 + 캐시) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                     # [필수] 24자 이상, 빈 값이면 --requirepass "" 로 무인증 기동됨

# ===== Redis Streams 토픽 이름 =====
STREAM_SENSOR_DATA=mg:sensor:data
STREAM_SENSOR_ALERT=mg:sensor:alert
STREAM_CONTROL_CMD=mg:control:cmd
STREAM_STATE_RESULT=mg:state:result
STREAM_AI_RESULT=mg:ai:result
STREAM_DB_WRITE=mg:db:write
STREAM_EMERGENCY_EVENT=mg:emergency:event

# ===== MQTT =====
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883
MQTT_USER=ems                       # [필수] entrypoint 에서 passwd/acl 생성에 사용
MQTT_PASSWORD=                      # [필수] 24자 이상 영숫자

# ===== API =====
API_SECRET_KEY=                     # [필수] 32자 이상 hex (Flask session)
JWT_SECRET=                         # [필수] 32자 이상 hex (JWT 서명)

# ===== OpenAI =====
OPENAI_API_KEY=                     # [필수] sk- 로 시작, OpenAI 대시보드에서 발급
